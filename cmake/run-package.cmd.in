@echo off
setlocal enableextensions

set "BUILD_DIR=@BUILD_DIR@"
set "VCPKG_INSTALLED_DIR=@VCPKG_INSTALLED_DIR@"
set "VCPKG_TARGET_TRIPLET=@VCPKG_TARGET_TRIPLET@"
set "POWERSHELL_EXE=@POWERSHELL_EXE@"
set "PACKAGE_SCRIPT=@PACKAGE_SCRIPT@"
set "STAGING_DIR=@STAGING_DIR@"
set "OUTPUT_DIR=@OUTPUT_DIR@"
set "VERSION=@VERSION@"
set "LOG_FILE=@LOG_FILE@"

set "CONFIG=%~1"
if not defined CONFIG set "CONFIG=Release"

if not exist "%BUILD_DIR%" (
  echo Build dir not found: "%BUILD_DIR%" > "%LOG_FILE%"
  exit /b 1
)

cd /d "%BUILD_DIR%" >nul 2>&1
if errorlevel 1 (
  echo Failed to cd to build dir: "%BUILD_DIR%" > "%LOG_FILE%"
  exit /b 1
)

echo Running packaging script... > "%LOG_FILE%"
echo BUILD_DIR=%BUILD_DIR%>>"%LOG_FILE%"
echo CONFIG=%CONFIG%>>"%LOG_FILE%"
echo STAGING_DIR=%STAGING_DIR%>>"%LOG_FILE%"
echo OUTPUT_DIR=%OUTPUT_DIR%>>"%LOG_FILE%"
echo VERSION=%VERSION%>>"%LOG_FILE%"
echo POWERSHELL_EXE=%POWERSHELL_EXE%>>"%LOG_FILE%"
echo PACKAGE_SCRIPT=%PACKAGE_SCRIPT%>>"%LOG_FILE%"
echo VCPKG_INSTALLED_DIR=%VCPKG_INSTALLED_DIR%>>"%LOG_FILE%"
echo VCPKG_TARGET_TRIPLET=%VCPKG_TARGET_TRIPLET%>>"%LOG_FILE%"

set "VCPKG_INSTALLED_DIR=%VCPKG_INSTALLED_DIR%"
set "VCPKG_TARGET_TRIPLET=%VCPKG_TARGET_TRIPLET%"

"%POWERSHELL_EXE%" -NoProfile -ExecutionPolicy Bypass -File "%PACKAGE_SCRIPT%" -BuildDir "%BUILD_DIR%" -Config "%CONFIG%" -StagingDir "%STAGING_DIR%" -OutputDir "%OUTPUT_DIR%" -Version "%VERSION%" >> "%LOG_FILE%" 2>>&1
exit /b %errorlevel%
