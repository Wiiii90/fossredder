@echo off
REM Launcher to set vcpkg debug bin into PATH and start fossredder.exe
setlocal
REM Detect MSVC debug CRT (vcruntime140d) under typical VS Redist locations and prepend if found
set "MSVCDIR="
if exist "%ProgramFiles%\Microsoft Visual Studio\2022\Community\VC\Redist\MSVC" (
  for /f "delims=" %%d in ('dir /b /ad "%ProgramFiles%\Microsoft Visual Studio\2022\Community\VC\Redist\MSVC" 2^>nul') do (
    if exist "%ProgramFiles%\Microsoft Visual Studio\2022\Community\VC\Redist\MSVC\%%d\debug_nonredist\x64\Microsoft.VC143.DebugCRT\vcruntime140d.dll" (
      set "MSVCDIR=%ProgramFiles%\Microsoft Visual Studio\2022\Community\VC\Redist\MSVC\%%d\debug_nonredist\x64\Microsoft.VC143.DebugCRT"
      goto :msvc_found
    )
  )
)
if exist "%ProgramFiles(x86)%\Microsoft Visual Studio\2022\Community\VC\Redist\MSVC" (
  for /f "delims=" %%d in ('dir /b /ad "%ProgramFiles(x86)%\Microsoft Visual Studio\2022\Community\VC\Redist\MSVC" 2^>nul') do (
    if exist "%ProgramFiles(x86)%\Microsoft Visual Studio\2022\Community\VC\Redist\MSVC\%%d\debug_nonredist\x64\Microsoft.VC143.DebugCRT\vcruntime140d.dll" (
      set "MSVCDIR=%ProgramFiles(x86)%\Microsoft Visual Studio\2022\Community\VC\Redist\MSVC\%%d\debug_nonredist\x64\Microsoft.VC143.DebugCRT"
      goto :msvc_found
    )
  )
)
:msvc_found
if defined MSVCDIR (
  set "PATH=%MSVCDIR%;@VCPKG_INSTALLED_DIR@\@VCPKG_TARGET_TRIPLET@\debug\bin;%PATH%"
) else (
  set "PATH=@VCPKG_INSTALLED_DIR@\@VCPKG_TARGET_TRIPLET@\debug\bin;%PATH%"
)
set "QT_DEBUG_PLUGINS=1"
cd /d "%~dp0"
"%~dp0\fossredder.exe" %*
endlocal
