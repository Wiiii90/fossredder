@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(OpenCV REQUIRED)

if(NOT "@FOSSREDDER_QT_PUBLIC_COMPONENTS@" STREQUAL "")
    find_dependency(Qt6 REQUIRED COMPONENTS @FOSSREDDER_QT_PUBLIC_COMPONENTS@)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/FossRedderTargets.cmake")

check_required_components(FossRedder)
