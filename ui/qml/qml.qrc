        <!-- Component controls -->
        <file>components/controls/AppButton.qml</file>
        <file>components/controls/AppTextField.qml</file>
        <file>components/controls/AppTextArea.qml</file>
        <file>components/controls/AppCheckBox.qml</file>
        <file>components/controls/AppComboBox.qml</file>

        <!-- Utilities -->
        <file>components/utils/FileUtils.js</file>

        <!-- Views -->
        <file>components/views/ActorsSidebar.qml</file>
        <file>components/views/ActorsView.qml</file>
        <file>components/views/BookingSidebar.qml</file>
        <file>components/views/BookingStatementsSidebar.qml</file>
        <file>components/views/BookingStatementsView.qml</file>
        <file>components/views/BookingTransactionsView.qml</file>
        <file>components/views/BookingView.qml</file>
        <file>components/views/ContractsSidebar.qml</file>
