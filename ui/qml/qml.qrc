        <file>components/views/ImportRunsList.qml</file>
        <file>components/views/ImportSidebar.qml</file>
        <file>components/views/ImportView.qml</file>
        <file>components/views/PlaceholderSidebar.qml</file>
        <file>components/views/PlaceholderView.qml</file>
        <file>components/views/PropertiesSidebar.qml</file>
        <file>components/views/PropertiesView.qml</file>
        <file>components/views/StatementDraftView.qml</file>
        <file>components/views/TransactionDraftView.qml</file>

        <!-- Assets -->
        <file>assets/annual.svg</file>
        <file>assets/analysis.svg</file>
        <file>assets/actor.svg</file>
        <file>assets/booking.svg</file>
        <file>assets/contract.svg</file>
