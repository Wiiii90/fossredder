{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 0,
    "patch": 1
  },
  "configurePresets": [
    {
      "hidden": true,
      "name": "vcpkg-base",
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_APPLOCAL_DEPS": "ON"
      },
      "environment": {
        "QT_DEBUG_PLUGINS": "1"
      }
    },
    {
      "hidden": true,
      "name": "vcpkg-ninja-base",
      "generator": "Ninja Multi-Config",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_APPLOCAL_DEPS": "ON"
      },
      "environment": {
        "QT_DEBUG_PLUGINS": "1"
      }
    },
    {
      "name": "app",
      "displayName": "App",
      "inherits": "vcpkg-base",
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "cacheVariables": {
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "app-fast",
      "displayName": "App Fast QML",
      "inherits": "app",
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "cacheVariables": {
        "FOSSREDDER_FAST_QML_BUILD": "ON"
      }
    },
    {
      "name": "app-ninja-fast",
      "displayName": "App Ninja Fast QML",
      "inherits": "vcpkg-ninja-base",
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "cacheVariables": {
        "BUILD_TESTING": "OFF",
        "FOSSREDDER_FAST_QML_BUILD": "ON"
      }
    },
    {
      "name": "tests",
      "displayName": "Tests",
      "inherits": "vcpkg-base",
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_CORE_TESTS": "ON",
        "BUILD_UI_TESTS": "ON",
        "BUILD_PERSISTENCE_TESTS": "ON",
        "BUILD_DEBUG_TESTS": "ON",
        "BUILD_OPENCV_TESTS": "ON",
        "BUILD_INFRA_ARCHIVE_TESTS": "ON",
        "BUILD_INFRA_PDF_RENDERING_TESTS": "ON",
        "BUILD_INFRA_TEXT_RECOGNITION_TESTS": "ON",
        "BUILD_INFRA_ANALYSIS_IMAGE_RENDERER_TESTS": "ON",
        "BUILD_INFRA_XLSX_WRITER_TESTS": "ON"
      }
    },
    {
      "name": "tests-fast",
      "displayName": "Tests Fast QML",
      "inherits": "tests",
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "cacheVariables": {
        "FOSSREDDER_FAST_QML_BUILD": "ON"
      }
    },
    {
      "name": "tests-ninja-fast",
      "displayName": "Tests Ninja Fast QML",
      "inherits": "vcpkg-ninja-base",
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_CORE_TESTS": "ON",
        "BUILD_UI_TESTS": "ON",
        "BUILD_PERSISTENCE_TESTS": "ON",
        "BUILD_DEBUG_TESTS": "ON",
        "BUILD_OPENCV_TESTS": "ON",
        "BUILD_INFRA_ARCHIVE_TESTS": "ON",
        "BUILD_INFRA_PDF_RENDERING_TESTS": "ON",
        "BUILD_INFRA_TEXT_RECOGNITION_TESTS": "ON",
        "BUILD_INFRA_ANALYSIS_IMAGE_RENDERER_TESTS": "ON",
        "BUILD_INFRA_XLSX_WRITER_TESTS": "ON",
        "FOSSREDDER_FAST_QML_BUILD": "ON"
      }
    },
    {
      "name": "ci",
      "displayName": "CI",
      "inherits": "tests",
      "binaryDir": "${sourceDir}/.build/${presetName}"
    },
    {
      "name": "tidy",
      "displayName": "Tidy",
      "inherits": "ci",
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "cacheVariables": {
        "FOSSREDDER_ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage",
      "inherits": "ci",
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "toolset": "ClangCL",
      "cacheVariables": {
        "FOSSREDDER_ENABLE_COVERAGE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug-app",
      "configurePreset": "app",
      "configuration": "Debug"
    },
    {
      "name": "release-app",
      "configurePreset": "app",
      "configuration": "Release"
    },
    {
      "name": "debug-app-fast",
      "configurePreset": "app-fast",
      "configuration": "Debug"
    },
    {
      "name": "release-app-fast",
      "configurePreset": "app-fast",
      "configuration": "Release"
    },
    {
      "name": "debug-app-ninja-fast",
      "configurePreset": "app-ninja-fast",
      "configuration": "Debug"
    },
    {
      "name": "release-app-ninja-fast",
      "configurePreset": "app-ninja-fast",
      "configuration": "Release"
    },
    {
      "name": "debug-tests",
      "configurePreset": "tests",
      "configuration": "Debug"
    },
    {
      "name": "release-tests",
      "configurePreset": "tests",
      "configuration": "Release"
    },
    {
      "name": "debug-tests-fast",
      "configurePreset": "tests-fast",
      "configuration": "Debug"
    },
    {
      "name": "release-tests-fast",
      "configurePreset": "tests-fast",
      "configuration": "Release"
    },
    {
      "name": "debug-tests-ninja-fast",
      "configurePreset": "tests-ninja-fast",
      "configuration": "Debug"
    },
    {
      "name": "release-tests-ninja-fast",
      "configurePreset": "tests-ninja-fast",
      "configuration": "Release"
    },
    {
      "name": "release-ci",
      "configurePreset": "ci",
      "configuration": "Release"
    },
    {
      "name": "release-tidy",
      "configurePreset": "tidy",
      "configuration": "Release"
    },
    {
      "name": "release-coverage",
      "configurePreset": "coverage",
      "configuration": "Release"
    },
    {
      "name": "release-package",
      "configurePreset": "app",
      "configuration": "Release",
      "targets": [
        "package"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "debug-tests",
      "configurePreset": "tests",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-tests",
      "configurePreset": "tests",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-ci",
      "configurePreset": "ci",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-coverage",
      "configurePreset": "coverage",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
