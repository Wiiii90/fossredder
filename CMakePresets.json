{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "x64-vcpkg",
      "displayName": "x64 (vcpkg)",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "architecture": {
        "value": "x64"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/third_party/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/third_party/vcpkg/installed",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_APPLOCAL_DEPS": "ON"
      },
      "environment": {
        "QT_DEBUG_PLUGINS": "1"
      }
    },
    {
      "hidden": true,
      "name": "Qt",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QTDIR}"
      },
      "vendor": {
        "qt-project.org/Qt": {
          "checksum": "wVa86FgEkvdCTVp1/nxvrkaemJc="
        }
      }
    }
  ],
  "buildPresets": [
    {
      "name": "x64-debug-vcpkg",
      "configurePreset": "x64-vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "x64-release-vcpkg",
      "configurePreset": "x64-vcpkg",
      "configuration": "Release"
    }
  ],
  "vendor": {
    "qt-project.org/Presets": {
      "checksum": "ZyBj5Q0MTVYPu8yTpACszd1R5vY="
    }
  }
}