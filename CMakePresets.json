{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 0,
    "patch": 1
  },
  "configurePresets": [
    {
      "hidden": true,
      "name": "vcpkg-base",
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/.build/vcpkg_installed",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_APPLOCAL_DEPS": "ON"
      },
      "environment": {
        "QT_DEBUG_PLUGINS": "1"
      }
    },
    {
      "name": "app",
      "displayName": "App",
      "inherits": [
        "vcpkg-base"
      ],
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "cacheVariables": {}
    },
    {
      "name": "tests",
      "displayName": "Tests",
      "inherits": [
        "vcpkg-base"
      ],
      "binaryDir": "${sourceDir}/.build/${presetName}",
      "cacheVariables": {
        "BUILD_CORE_TESTS": "ON",
        "BUILD_PERSISTENCE_TESTS": "ON",
        "BUILD_DEBUG_TESTS": "ON"
      }
    },
    {
      "hidden": true,
      "name": "Qt",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QTDIR}"
      },
      "vendor": {
        "qt-project.org/Qt": {
          "checksum": "wVa86FgEkvdCTVp1/nxvrkaemJc="
        }
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug-app",
      "configurePreset": "app",
      "configuration": "Debug"
    },
    {
      "name": "release-app",
      "configurePreset": "app",
      "configuration": "Release"
    },
    {
      "name": "debug-tests",
      "configurePreset": "tests",
      "configuration": "Debug"
    },
    {
      "name": "release-tests",
      "configurePreset": "tests",
      "configuration": "Release"
    },
    {
      "name": "release-package",
      "configurePreset": "app",
      "configuration": "Release",
      "targets": [
        "package"
      ]
    }
  ],
  "vendor": {
    "qt-project.org/Presets": {
      "checksum": "Ll8Va7sdj8Niaf4Ck0TEGeyO+2Q="
    }
  }
}